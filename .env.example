# --- Claude Agent SDK ---------------------------------------------------------
# Isolated config dir the SDK subprocess inherits (auth + model mapping).
# A leading `~` is expanded to an absolute path at startup (src/config.ts).
CLAUDE_CONFIG_DIR=~/.estival

# --- HTTP server --------------------------------------------------------------
# Listen port.
PORT=3000
# Agent runs executing at once; beyond this, requests queue.
MAX_CONCURRENCY=4
# Max requests allowed to wait for a slot; beyond this the server returns 503.
MAX_QUEUE=20
# Wall-clock budget for a single agent run (ms); the run aborts as "timeout" past it.
AGENT_TIMEOUT_MS=120000
# Max turns per run; 0 (or negative) = unlimited (still bounded by AGENT_TIMEOUT_MS).
AGENT_MAX_TURNS=10
# Max request body accepted by express.json().
MAX_BODY=256kb

# --- Logging ------------------------------------------------------------------
# Minimum level: debug < info < warn < error. Set debug for per-run detail.
LOG_LEVEL=info
# Output format: text (human-readable) or json (one object per line).
LOG_FORMAT=text

# --- Files (uploads / resolved file params) -----------------------------------
# Directory for uploaded + resolved files. Defaults to the system temp dir.
# FILES_DIR=/var/lib/estival/files
# Max single uploaded file size.
MAX_FILE_SIZE=10mb
# Temp file retention in hours; files older than this are swept. Default 180 days.
FILE_TTL_HOURS=4320
# Base URL for resolving `resolve: file` params that carry remote references.
# OSS_BASE_URL=https://files.example.com

# --- Async tasks (optional) ---------------------------------------------------
# PostgreSQL connection string enables the submit/detail endpoints. Unset → those
# two endpoints return 503; the sync and stream endpoints work without a database.
# DATABASE_URL=postgres://user:pass@host:5432/estival
# Retention for finished task rows in hours; 0 = never prune.
TASK_TTL_HOURS=0

# --- Global MCP servers (optional) --------------------------------------------
# Path to a global MCP config ({ "mcpServers": {...} }) visible to every skill.
# Defaults to ./.claude/mcp.json if present.
# GLOBAL_MCP_PATH=./.claude/mcp.json
